# ── Meshy AI (required) ────────────────────────────────────────────────────
MESHY_API_KEY=msy_...

# ── ElevenLabs TTS (optional — falls back to espeak / macOS say) ───────────
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── InsForge cloud storage (optional — upload skipped if missing or > 20 MB)
INSFORGE_API_KEY=ik_...
INSFORGE_BASE_URL=https://....insforge.app
INSFORGE_PROJECT_ID=...
INSFORGE_STORAGE_BUCKET_MODELS=morph-forge-models
INSFORGE_STORAGE_BUCKET_CONJURE=conjure-models

# ── Supabase (optional — dual-write gallery + event log + file backup) ─────
# Use the anon key. Bucket must already exist and be set to Public.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_BUCKET=conjure-models

# ── Slicing (Orange Pi paths) ──────────────────────────────────────────────
ORCASLICER_PATH=/home/orangepi/OrcaSlicer/orca-slicer
ORCASLICER_PROFILE=/home/orangepi/conjure-kiosk/profiles/neptune4pro_orca.json
CURAENGINE_PATH=/usr/bin/CuraEngine
CURA_RESOURCES_PATH=/usr/share/cura/resources
PRINTER_PROFILE=neptune4pro

# ── Paths ──────────────────────────────────────────────────────────────────
USB_MOUNT_PATH=/media/usb
OUTPUT_DIR=/home/orangepi/conjure-kiosk/output
